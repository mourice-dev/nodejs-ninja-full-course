<!-- @format -->

<!DOCTYPE html>
<html lang="en">
  <%- include('./partials/header.ejs' ) %>

  <body>
    <%- include('./partials/nav.ejs') %>
    <h3>Title:<%= blog.title %></h3>

    <p>Snippet:<%= blog.snippet %></p>
    <br />
    <br />
    <p>body:<%= blog.body %></p>
    <br />
    <a class="delete button" data-doc=<%= blog.id %> style="cursor: pointer"
      >delete</a
    >

    <%- include('./partials/footer.ejs') %>
    <script>
      const transfac = document.querySelector(".delete");
      transfac.addEventListener("click", (e) => {
        fetch(`/blogs/${transfac.dataset.doc}`, {
          method: "DELETE",
        })
          .then((response) => response.json())
          .then((data) => (window.location.href = data.redirect))
          .catch((err) => console.log(err));
      });
    </script>
  </body>
</html>
